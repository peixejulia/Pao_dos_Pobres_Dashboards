# Copie este arquivo para ".streamlit/secrets.toml" (esse sim é ignorado pelo
# git) e preencha com os valores reais. NUNCA coloque valores reais aqui
# neste arquivo .example, ele fica no repositório público.
#
# No Streamlit Community Cloud, os mesmos valores vão em:
#   Manage app -> ⋮ -> Settings -> Secrets

# Senha para acessar a página "Gerenciar Dados". Escolha algo simples de
# compartilhar com a equipe da Fundação, mas que não seja óbvio.
senha_gerenciar_dados = "troque-esta-senha"

[github]
# Personal Access Token do GitHub com permissão de escrita neste
# repositório (escopo "repo" se for token clássico, ou "Contents:
# read and write" se for um token "fine-grained").
token = "cole_aqui_o_token"

# "usuario/nome-do-repositorio"
repo = "peixejulia/Pao_dos_Pobres_Dashboards"

# Branch onde o Streamlit Cloud está de olho (normalmente "main")
branch = "main"
